# Local development environment variables for Docker Compose
# Copy this file to .env and fill in your actual values
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your actual secrets
#   docker compose up

# Organization API codes for waste-movement-backend service
ORG_API_CODES=your-org-api-codes-here
WASTE_TRACKING_ID_BACKEND_VERSION=latest
WASTE_TRACKING_EXTERNAL_API_VERSION=latest
WASTE_ORGANISATION_BACKEND_VERSION=latest

# Service-to-service authentication credentials (base64 encoded username=password pairs)
# Example: echo -n "waste-movement-external-api=your-secret" | base64
ACCESS_CRED_WASTE_MOVEMENT_EXTERNAL_API=your-base64-encoded-credentials-here

# Service-to-service authentication credentials (base64 encoded username=password pairs)
# Example: echo -n "waste-movement-backend=your-secret" | base64
ACCESS_CRED_WASTE_MOVEMENT_BACKEND=your-base64-encoded-credentials-here

# Service-to-service authentication credentials (base64 encoded username=password pairs)
# Example: echo -n "waste-organisation-backend=your-secret" | base64
ACCESS_CRED_WASTE_ORGANISATION_BACKEND=your-base64-encoded-credentials-here

# QA non-prod endpoint authentication credentials (base64 encoded username=password pairs)
# Example: echo -n "qa-non-prod=your-secret" | base64
ACCESS_CRED_QA_NON_PROD=your-base64-encoded-credentials-here

# Password for external-api to authenticate with backend services
# Must match the password in ACCESS_CRED_WASTE_MOVEMENT_EXTERNAL_API above
SERVICE_AUTH_PASSWORD=your-password-here

# Password for waste-movement-backend to authenticate with backend services
# Must match the password in ACCESS_CRED_WASTE_MOVEMENT_BACKEND above
SERVICE_AUTH_PASSWORD_WASTE_MOVEMENT_BACKEND=your-password-here

# Password to authenticate with waste-organisation-backend service
WASTE_CLIENT_AUTH_WASTE_MOVEMENT_EXTERNAL_API=your-password-here

# Maximum number of records allowed in a bulk upload request (default: 100)
MAX_BULK_RECORDS=100

# Determines if the Waste Organisation Backend is available
IS_WASTE_ORGANISATION_BACKEND_AVAILABLE=false
